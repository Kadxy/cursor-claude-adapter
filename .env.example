# cursor-claude-adapter config. Copy to .env and adjust.
#   cp .env.example .env

# Upstream Anthropic service. HOST ONLY — do NOT append /v1/messages,
# the code adds that path itself. (e.g. http://host:3003, https://api.example.com)
UPSTREAM_URL=http://152.53.52.170:3003

# Prefix stripped before forwarding (cursor-claude-opus-4-8 -> claude-opus-4-8).
MODEL_PREFIX=cursor-

# anthropic-version header sent upstream.
ANTHROPIC_VERSION=2023-06-01

# Host port published by docker-compose (container is always 3000).
PORT=3000

# Interface the published port binds to. 127.0.0.1 = loopback only
# (reach it via a tunnel, e.g. cloudflared). Set 0.0.0.0 to listen on all NICs.
BIND=127.0.0.1

# Set to 1 to log request/response summaries.
DEBUG=0
